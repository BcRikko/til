---
interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props;
---

<section class="demo-browser">
  <header class="header">
    <div class="controls" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>

    <h2 class="title">{title}</h2>
  </header>

  <section class="body" id={id}>
    <slot />
  </section>
</section>

<style>
  .demo-browser {
    border-radius: 8px;
    box-shadow: 0 2px 10px 2px rgb(from #333 r g b / 0.2);

    .header {
      border-radius: 8px 8px 0 0;
      display: grid;
      grid-template-columns: auto 1fr;
      align-items: center;
      gap: 1rem;
      height: 2rem;

      padding: 0 0.8em;

      color: #fafafa;
      background-color: #333;

      .title {
        font-size: 0.7rem;
        font-weight: bold;
        margin: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .controls {
        display: flex;
        gap: 8px;

        span {
          width: 12px;
          height: 12px;
          border-radius: 50%;

          &:nth-child(1) {
            background-color: #ff5f57;
          }
          &:nth-child(2) {
            background-color: #febc2e;
          }
          &:nth-child(3) {
            background-color: #28c840;
          }
        }
      }
    }

    .body {
      padding: 0.2em;
      border-radius: 0 0 8px 8px;
    }
  }
</style>
