---
import Meta from "../components/Meta.astro";
import GoogleFont from "../components/GoogleFont.astro";
import Ads from "../components/Ads.astro";
import SNS from "../components/SNS.astro";
import Byline from "../components/Byline.astro";
import Discover from "../components/Discover.astro";
import Search from "../components/Search.astro";

import "../styles/global.css";
import "../styles/plugins.css";

interface Props {
  title: string;
  description: string;
  tags: string;
  pubDate: string;
  updatedDate: string;
  /**
   * pagefindのインデックスから除外する
   */
  "data-pagefind-ignore"?: boolean;
}

const {
  title,
  description,
  tags,
  pubDate,
  updatedDate,
  url,
  "data-pagefind-ignore": dataPagefindIgnore,
} = (Astro.props as any)?.frontmatter ?? Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/vnd.microsoft.icon" href="/til/favicon.ico" />
    <link rel="sitemap" href="/til/sitemap-index.xml" />

    <Meta title={title} description={description} tags={tags} url={url} />
    <GoogleFont />

    <title>{title} | @bc_rikko</title>

    <Byline
      title={title}
      description={description}
      pubDate={pubDate}
      updatedDate={updatedDate}
    />
    <SNS />
    <Discover rss="/til/rss" />
  </head>
  <body>
    <header>
      <a href="/til">≪ Today I learned.</a>

      <div class="actions">
        <a
          class="rss-link"
          href="/til/rss"
          target="_blank"
          aria-label="RSSフィードを購読する"
        >
          RSS購読
        </a>

        <Search />
      </div>
    </header>

    <main
      {...dataPagefindIgnore === true
        ? { "data-pagefind-ignore": true }
        : { "data-pagefind-body": true }}
    >
      <slot />
    </main>

    <aside class="ads">
      <Ads />
    </aside>

    <footer>
      <p>
        <small>
          Copyright © 2024{" "}
          <a href="https://x.com/bc_rikko" target="_blank">
            ダーシノ(@bc_rikko)
          </a>
        </small>
      </p>
    </footer>
  </body>
</html>

<style>
  header {
    display: flex;
    justify-content: space-between;
    align-items: center;

    .rss-link {
      border-radius: 0.3em;
      padding-inline: 0.5em;
      border: 2px solid;
      padding-block: 1px;
      text-decoration: none;
      color: inherit;
    }

    .actions {
      display: flex;
      gap: 0.5rem;
      align-items: center;
    }
  }
  .ads {
    padding-inline: 0;
  }
  footer {
    text-align: center;
  }
</style>
